# ---------------------------------------------------------------------
# Copy this file to ".env" before running "docker compose up --build".
# docker-compose reads it automatically.
# ---------------------------------------------------------------------

# PostgreSQL
POSTGRES_DB=cabinet_medical
POSTGRES_USER=cabinet_user
POSTGRES_PASSWORD=cabinet_password
POSTGRES_PORT=5432

# Spring Boot application
APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Security - CHANGE THIS in a real deployment (min. 32 characters)
APP_JWT_SECRET=pt28-cabinet-medical-very-secret-key-change-me-in-production-256bits
